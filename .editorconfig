# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# GDScript requires tabs (Godot enforces this)
[*.gd]
indent_style = tab
indent_size = 4

[*.{tscn,tres,godot}]
indent_style = tab
indent_size = 4
